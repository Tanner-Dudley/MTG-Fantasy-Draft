# Copy this file to .env and fill in your values.
# .env is in .gitignore and will NOT be committed to git.

# Secret key used to sign JWT tokens. Use any long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-string

# Database URL (not used yet -- will be added in the DB phase)
# For local SQLite:   sqlite:///./dev.db
# For Postgres:       postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./dev.db
